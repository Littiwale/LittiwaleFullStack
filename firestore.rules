rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPER FUNCTIONS ──
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isRider() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'rider';
    }

    function isManager() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager';
    }

    function isAdminOrManager() {
      return isAdmin() || isManager();
    }

    // ── USERS ──
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read, write: if isAdmin(); // Admin reads ALL users

      // Saved addresses subcollection (max 3 enforced client-side)
      match /addresses/{addressId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
        allow read: if isAdmin();
      }
    }

    // ── USERNAME / PHONE UNIQUENESS ──
    match /usernames/{username} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /phones/{phone} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── ORDERS ──
    match /orders/{orderId} {
      // Only logged-in users can place orders
      allow create: if request.auth != null;

      // Customer reads their own order
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;

      // Phone fallback (for guest-recovery flows)
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.phone == resource.data.customer.phone;

      // Admin / Manager — full control
      allow read, write: if isAdminOrManager();

      // Rider — read and update only their assigned order (status + deliveredAt only)
      allow read: if isRider() && resource.data.riderId == request.auth.uid;
      allow update: if isRider() &&
        resource.data.riderId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'deliveredAt', 'updatedAt']);

      // Ratings subcollection on each order
      match /rating/{ratingId} {
        // Owner of the order can write their rating
        allow create, update: if request.auth != null &&
          get(/databases/$(database)/documents/orders/$(orderId)).data.userId == request.auth.uid;
        // Anyone who can read the order can read the rating
        allow read: if request.auth != null &&
          (get(/databases/$(database)/documents/orders/$(orderId)).data.userId == request.auth.uid
            || isAdminOrManager());
      }
    }

    // ── MENU ──
    match /menu/{itemId} {
      allow read: if true;
      allow write: if isAdminOrManager();
    }

    // ── ANNOUNCEMENTS ──
    match /announcements/{docId} {
      allow read: if true;
      allow write: if isAdminOrManager();
    }

    // ── COUPONS ──
    // Any logged-in user can read coupons (needed for checkout validation)
    // Only admin / manager can create, update, or delete
    match /coupons/{couponId} {
      allow read: if request.auth != null;
      allow write: if isAdminOrManager();
    }

  }
}