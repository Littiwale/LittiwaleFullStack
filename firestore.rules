rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPER FUNCTIONS ──
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isRider() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'rider';
    }

    // ── USERS ──
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read, write: if isAdmin(); // Admin reads ALL users
    }

    // ── USERNAME / PHONE UNIQUENESS ──
    match /usernames/{username} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /phones/{phone} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── ORDERS ──
    match /orders/{orderId} {
      allow create: if request.auth != null;

      // Customer apna order
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;

      // Phone fallback
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.phone == resource.data.phone;

      // ✅ Admin — full control (READ bhi)
      allow read, write: if isAdmin();

      // Rider — sirf apna assigned order
      allow read: if isRider() && resource.data.riderId == request.auth.uid;
      allow update: if isRider() &&
        resource.data.riderId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'deliveredAt']);
    }

    // ── MENU ──
    match /menu/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── ANNOUNCEMENTS ──
    match /announcements/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}