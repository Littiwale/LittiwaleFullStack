rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users Profile: Only the owner can read/write their own data
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      
      // Admin bypass (optional but common)
      allow read: if request.auth != null && 
                  get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Atomic Uniqueness Reservation
    match /usernames/{username} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /phones/{phone} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Orders Tracking: Strictly restricted to the owner by userId
    match /orders/{orderId} {
      allow create: if request.auth != null;
      
      // Only the authenticated buyer can read their specific order
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      
      // Secondary check: If UID missing, check if phone matches (for legacy/edge cases)
      allow read: if request.auth != null && 
                  get(/databases/$(database)/documents/users/$(request.auth.uid)).data.phone == resource.data.phone;

      // Only admins can modify status/details
      allow update, delete: if request.auth != null && 
                            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Menu and other public data
    match /menu/{itemId} {
      allow read: if true;
      allow write: if request.auth != null && 
                    get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Announcements public read access
    match /announcements/{docId} {
      allow read: if true;
      allow write: if request.auth != null && 
                    get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
